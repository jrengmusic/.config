{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)"
    ],
    "deny": [
      "Bash(git reset --hard*)",
      "Bash(git checkout --*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.carol/bin/carol-statusline.sh"
  },
  "enabledPlugins": {},
  "effortLevel": "medium",
  "promptSuggestionEnabled": false,
  "awaySummaryEnabled": false,
  "showTurnDuration": false,
  "model": "claude-opus-4-6[1m]"
}
