# OS detection
if [[ "$OSTYPE" == "msys" || "$OSTYPE" == "cygwin" ]]; then
  OPERATING_SYSTEM="windows"
elif [[ "$(uname -m)" == "arm64" ]]; then
  OPERATING_SYSTEM="macos-arm"
else
  OPERATING_SYSTEM="macos-intel"
fi

# Package paths
if [[ $OPERATING_SYSTEM == "macos-arm" ]]; then
  _FZF_SHARE="/opt/homebrew/opt/fzf/shell"
  _ZSH_HL="/opt/homebrew/share/zsh-syntax-highlighting"
elif [[ $OPERATING_SYSTEM == "macos-intel" ]]; then
  _FZF_SHARE="/opt/local/share/fzf/shell"
  _ZSH_HL="/opt/local/share/zsh-syntax-highlighting"
elif [[ $OPERATING_SYSTEM == "windows" ]]; then
  _FZF_SHARE="/mingw64/share/fzf"
  _ZSH_HL="/usr/share/zsh-syntax-highlighting"
fi

alias vim="nvim"
alias :q="exit"

autoload -Uz compinit && compinit
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'

#shortcuts
alias kuassa='cd ~/Documents/Poems/kuassa'
alias lib='cd ~/Documents/Poems/kuassa/___lib___'
alias inf='cd ~/Documents/Poems/inf'
alias dev='cd ~/Documents/Poems/dev'
alias modules='cd ~/Documents/Poems/inf/___modules___/'

alias ls='eza -la'
alias keju='~/Documents/Poems/inf/___user-modules___/automation/Keju_x64'

# Windows-only aliases
if [[ $OPERATING_SYSTEM == "windows" ]]; then
  alias amp='AMP_HOME=/c/Users/jreng/.amp AMP_RIPGREP_PATH=/c/Users/jreng/.amp/bin/rg.exe /c/Users/jreng/.amp/bin/bun.exe run --cwd /c/Users/jreng/.amp/package /c/Users/jreng/.amp/package/dist/main.js'
fi

# fzf configuration
# Dot directories to always include
DOT_INCLUDE=(".config" ".local" ".carol")

# Individual dotfiles to include (in home directory)
DOT_FILES=(".zshrc" ".zprofile" ".zshenv" ".gitconfig")

# Directories/files to exclude
EXCLUDE_PATTERNS=(
  "*.noindex*"
  "*/.DS_Store"
  "*/node_modules/*"
  "*/.git/*"
  "*/.cache/*"
  "*/build/*"
  "*/dist/*"
  "*/.vscode/*"
  "*/Library/*"
)

# Build the find pattern for dot directories
DOT_PATTERN=""
for dir in "${DOT_INCLUDE[@]}"; do
  DOT_PATTERN="$DOT_PATTERN -o -path \"*/$dir/*\""
done

# Add individual dotfiles
for file in "${DOT_FILES[@]}"; do
  DOT_PATTERN="$DOT_PATTERN -o -name \"$file\""
done

# Build exclusion pattern
EXCLUDE=""
for pattern in "${EXCLUDE_PATTERNS[@]}"; do
  EXCLUDE="$EXCLUDE -not -path \"$pattern\""
done

# Exclude hidden files EXCEPT specific dot directories/files, and exclude garbage
export FZF_CTRL_T_COMMAND="find . -type f $EXCLUDE \( -not -path \"*/\.*\" $DOT_PATTERN \)"

[ -f "$_FZF_SHARE/key-bindings.zsh" ] && source "$_FZF_SHARE/key-bindings.zsh"
[ -f "$_FZF_SHARE/completion.zsh" ]   && source "$_FZF_SHARE/completion.zsh"

# Custom fzf options
export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=numbers --line-range=:500 {}' \
  --bind 'ctrl-v:execute(nvim {})' \
  --bind 'ctrl-o:execute(open {})' \
  --bind 'ctrl-y:execute-silent(echo {} | pbcopy)+abort'"

# Ctrl+F for file search
bindkey '^F' fzf-file-widget

# zsh-syntax-highlighting
[ -f "$_ZSH_HL/zsh-syntax-highlighting.zsh" ] && source "$_ZSH_HL/zsh-syntax-highlighting.zsh"

