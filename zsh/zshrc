ZSH_HIGHLIGHT_STYLES[bracket-level-5]="fg=#808080"             # delimiter gray
ZSH_HIGHLIGHT_STYLES[cursor-matchingbracket]="fg=#ffffff,bg=#4080ff,bold" # matching paren
# cmake (macos-intel: official download, no pkg manager)
if [[ $OPERATING_SYSTEM == "macos-intel" ]]; then
  export PATH="$HOME/Library/cmake-4.2.0-macos-universal/CMake.app/Contents/bin:$PATH"
fi

# bun completions
[ -s "~/.bun/_bun" ] && source "~/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# opencode
export PATH=~/.opencode/bin:$PATH

# This initializes zoxide and sets up the 'cd' alias automatically
eval "$(zoxide init zsh --cmd cd)"
alias zi='__zoxide_zi'

# Oh my posh
if [ "$TERM_PROGRAM" != "Apple_Terminal" ] && command -v oh-my-posh &>/dev/null; then
  eval "$(oh-my-posh init zsh --config ~/.config/omp/gfx.json)"
fi
