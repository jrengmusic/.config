ZSH_HIGHLIGHT_STYLES[arg0]="fg=#80ffff"                        # func cyan
ZSH_HIGHLIGHT_STYLES[bracket-error]="fg=#f74a4a,bold"          # error red
ZSH_HIGHLIGHT_STYLES[bracket-level-1]="fg=#808080"             # delimiter gray
