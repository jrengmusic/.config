# Doxyfile.lib — JRENG framework library template
# Generated per-lib by doxygen.lua — do not run directly.
# Ground of truth: JUCE/docs/doxygen/Doxyfile (inherited via @INCLUDE).
# Run from: {lib}/docs/   (OUTPUT_DIRECTORY blank → cwd)
# Output:   {lib}/docs/html/  {lib}/docs/xml/  {lib}/docs/tagfile.xml
#           {lib}/DOCS.html   (root redirect, written by build-doxygen.sh)
#
# Substitution markers (applied by doxygen.lua):
#   JUCE_DOXYFILE, PROJECT_NAME, PROJECT_BRIEF
#   INPUT, TAGFILES, DOT_MAX_NODES, EXCLUDE_PATTERNS

@INCLUDE = __JUCE_DOXYFILE__

PREDEFINED += KUASSA_VULKAN_RUNTIME_SHADER_COMPILER=1

#---------------------------------------------------------------------------
# Per-lib overrides
#---------------------------------------------------------------------------

PROJECT_NAME           = "__PROJECT_NAME__"
PROJECT_BRIEF          = "__PROJECT_BRIEF__"
PROJECT_ICON           =
OUTPUT_DIRECTORY       =
EXTRACT_PRIVATE        = YES
INPUT                  = __INPUT__
STRIP_FROM_PATH        = __INPUT__
FILE_PATTERNS          = *.h *.cpp *.mm
RECURSIVE              = YES
EXCLUDE_PATTERNS       = __EXCLUDE_PATTERNS__
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_HEADER            =
HTML_FOOTER            =
HTML_EXTRA_STYLESHEET  =
HTML_EXTRA_FILES       =
GENERATE_XML           = YES
XML_OUTPUT             = xml
GENERATE_LATEX         = NO
USE_MATHJAX            = YES
GENERATE_TAGFILE       = tagfile.xml
TAGFILES               = __TAGFILES__
DOT_GRAPH_MAX_NODES    = __DOT_MAX_NODES__
